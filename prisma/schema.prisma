generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       BigInt  @id @default(autoincrement())
  email    String  @unique
  password String
  role     String  @default("admin") // admin | user
   cv_url    String?      // 🔹 Supabase CV file URL
  cv_name   String?      // 🔹 original file name
  cv_updated_at DateTime?
}

/// Contact messages
model Contact_msg {
  id         BigInt   @id @default(autoincrement())
  name       String   @default("not null")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  email      String   @default("not null")
  message    String?  @default("null")
}

/// Page views
model Page_views {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  ip         String?
  path       String?
}

/// Projects
model Project {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  title       String?
  description String?
  github_url  String?
  live_url    String?
  is_featured Boolean?
  thumbnail   String?
  category    String?

  skills      ProjectSkill[]
  images      Images[]   // ✅ Added relation to Images
}

/// Project images
model Images {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  url        String?
  projectId  BigInt
  project    Project @relation(fields: [projectId], references: [id])
}

/// Skills
model Skills {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  name       String?
  category   String?
  image_url  String?

  projects   ProjectSkill[]
}

/// Join table for Project & Skills (many-to-many)
model ProjectSkill {
  projectId BigInt
  skillId   BigInt
  project   Project @relation(fields: [projectId], references: [id],onDelete: Cascade)
  skill     Skills  @relation(fields: [skillId], references: [id],onDelete: Cascade)
  @@id([projectId, skillId])
}
